        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "lighthouse": "^13.0.3",
        "playwright": "^1.58.2",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
