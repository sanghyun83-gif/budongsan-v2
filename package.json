{
    "name": "budongsan-v2",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --webpack",
        "dev:turbo": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "db:normalize": "node scripts/run-sql.mjs sql/009_normalize_incremental.sql",
        "db:normalize:full": "node scripts/run-sql.mjs sql/003_normalize_from_raw.sql",
        "db:normalize:prepare": "node scripts/run-sql.mjs sql/007_normalize_perf_indexes.sql && node scripts/run-sql.mjs sql/008_pipeline_state.sql", 
        "qa:smoke": "node scripts/smoke-launch-gate.mjs",
        "qa:hub-p0-smoke": "node scripts/hub-p0-smoke.mjs",
        "qa:hub-manual-report": "node scripts/hub-manual-smoke-report.mjs",
        "qa:sync-benchmark-smoke": "node scripts/sync-manual-smoke-to-benchmark.mjs",
        "qa:listings-naver-fixture": "node scripts/listings-naver-fixture-smoke.mjs",
        "qa:sync-listings-fixture-benchmark": "node scripts/sync-listings-fixture-smoke-to-benchmark.mjs",
        "qa:listings-naver-fixture:all": "node scripts/listings-naver-fixture-all.mjs",
        "qa:commission-parity": "node scripts/commission-parity-smoke.mjs",
        "qa:commission-smoke": "node scripts/commission-smoke.mjs",
        "qa:legal-parity": "node scripts/legal-parity-smoke.mjs",
        "qa:lighthouse:mobile": "lighthouse http://localhost:3000 --output html --output-path ./docs/lighthouse-mobile.html --chrome-flags=\"--headless\"", 
        "ingest:molit": "node scripts/ingest-molit.mjs",
        "ingest:molit:max": "node scripts/ingest-molit.mjs --regionConcurrency=6 --monthConcurrency=4 --fetchConcurrency=6 --dbBatchSize=1500 --maxPerRegion=0 --normalizeInline=false", 
        "ingest:molit:rent": "node scripts/ingest-molit-rent.mjs", 
        "ingest:molit:rent:dry": "node scripts/ingest-molit-rent.mjs --dryRun=true", 
        "ingest:molit:rowhouse:sale": "node scripts/ingest-molit-rowhouse-trade.mjs",
        "ingest:molit:rowhouse:sale:dry": "node scripts/ingest-molit-rowhouse-trade.mjs --dryRun=true",
        "ingest:molit:seoul3m": "node scripts/ingest-molit.mjs --months=3",
        "ingest:molit:dry": "node scripts/ingest-molit.mjs --months=3 --dryRun=true",
        "db:indexes:mvp3": "node scripts/run-sql.mjs sql/004_mvp3_indexes.sql",
        "qa:parity": "node scripts/check-map-search-parity.mjs",
        "db:location-source": "node scripts/run-sql.mjs sql/005_location_source.sql",
        "db:geocode-schema": "node scripts/run-sql.mjs sql/006_geocode_backfill.sql",
        "geocode:enqueue": "node scripts/enqueue-geocode.mjs --onlyApprox=true --limit=1000",
        "geocode:backfill": "node scripts/backfill-geocode-kakao.mjs --batch=100",
        "ops:location-gate": "node scripts/check-location-gate.mjs --exactMin=0.8 --failMax=0.05",
        "geocode:maintain": "node scripts/geocode-maintain.mjs --rounds=6 --batch=50 --exactMin=0.8 --failMax=0.05 --strict=true"
    },
    "dependencies": {
        "@types/pg": "^8.16.0",
        "@upstash/redis": "^1.36.3",
        "@vercel/analytics": "^1.6.1",
        "@vercel/speed-insights": "^1.3.1",
        "next": "16.1.6",
        "pg": "^8.19.0",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "lighthouse": "^13.0.3",
        "playwright": "^1.58.2",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
}
